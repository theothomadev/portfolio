# RapidAPI key — subscribe to "Rocket League Tracker" on https://rapidapi.com
# Copy to .env.local for local dev. Add the same variable in Vercel for production.
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional — defaults to rocket-league-tracker.p.rapidapi.com
# RAPIDAPI_HOST=rocket-league-tracker.p.rapidapi.com
